# PostgreSQL connection
DATABASE_URL=postgresql://incomos:incomos@localhost:5432/incomos

# MiMo 2.5 API (used in Stage 2+, not needed for Phase 1)
# MIMO_API_KEY=your_key_here
# MIMO_API_BASE_URL=https://api.mimo.ai/v1

# FRED API (free, optional — unauthenticated access works for public series)
# FRED_API_KEY=your_key_here

# Base currency
BASE_CURRENCY=MYR

# EDGAR rate limit (requests per second — EDGAR policy: max 10/s)
EDGAR_REQUESTS_PER_SECOND=5

# Minimum quality screen thresholds (Stage 0→1)
MIN_DIVIDEND_YEARS=3          # Must have paid dividend for at least this many consecutive years
MAX_FCF_PAYOUT_RATIO=0.90     # FCF payout ratio ceiling for quality screen
MIN_FCF_POSITIVE_YEARS=3      # Must have positive FCF in at least this many of last 5 years
